# Database Configuration
# Runtime (app): any one of these — the app checks them in order.
# Vercel Postgres (Storage tab → Connect) injects POSTGRES_PRISMA_URL automatically.
DATABASE_URL="postgres://user:password@host:port/db-name"
# POSTGRES_PRISMA_URL="postgres://..."   # Vercel Postgres pooled (runtime)
# POSTGRES_URL="postgres://..."            # Vercel Postgres alternate
# POSTGRES_URL_NON_POOLING="postgres://..." # Vercel Postgres direct (Prisma CLI / migrations)
# DIRECT_URL="postgres://..."              # Prisma Postgres direct (migrations)

# Optional: Add connection pooling parameters for external PostgreSQL databases
# These parameters are ignored by Vercel Postgres (which handles pooling automatically)
# For self-hosted or other providers, you can add these to the DATABASE_URL:
#   ?connection_limit=20&statement_cache_size=20
# Example: DATABASE_URL="postgres://user:pass@localhost:5432/portfolio?sslmode=require&connection_limit=20"

# Email Configuration (for contact form)
# Required in production — do not use "console" on Vercel/production
EMAIL_SERVICE="resend"
# Options: console (dev only), resend, sendgrid, smtp

EMAIL_FROM="your-email@example.com"
CONTACT_EMAIL="your-email@example.com"
EMAIL_TO="your-email@example.com"

# Resend (when EMAIL_SERVICE=resend)
RESEND_API_KEY="re_xxxxxxxx"

# SendGrid (when EMAIL_SERVICE=sendgrid)
SENDGRID_API_KEY="SG.xxxxxxxx"

# SMTP (when EMAIL_SERVICE=smtp — not yet implemented in app)
EMAIL_SMTP_HOST="smtp.example.com"
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_USER="your-username"
EMAIL_SMTP_PASSWORD="your-password"
