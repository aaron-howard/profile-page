// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  // Vercel/serverless runs Linux; dev on Windows needs an extra engine in the bundle
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bio {
  id       Int     @id @default(1)
  name     String
  title    String
  location String
  about    String

  // Skills grouped by category (see scripts/seed-bio.js for shape)
  skillCategories Json @default("{}")

  // Experience stored as JSON array
  experience Json?

  // Public contact / social links (see src/lib/site-metadata.ts)
  siteMetadata Json @default("{}")

  updatedAt DateTime @updatedAt

  @@map("bio")
}

model BlogPost {
  id        Int       @id @default(autoincrement())
  title     String
  excerpt   String?
  content   String
  author    String
  date      DateTime
  category  String
  readTime  String?
  featured  Boolean   @default(false)
  tags      String[]

  @@map("blog_post")
}

model Project {
  id           Int       @id @default(autoincrement())
  title        String
  description  String
  image        String?
  technologies String[]
  category     String
  github       String?
  live         String?
  featured     Boolean   @default(false)

  @@map("project")
}