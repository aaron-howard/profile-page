// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String    @id
  age      Int?
  sessions Session[]

  @@map("user")
}

model Session {
  id        String   @id
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("session")
}

model BlogPost {
  id        Int       @id @default(autoincrement())
  title     String
  excerpt   String?
  content   String
  author    String
  date      DateTime
  category  String
  readTime  String?
  featured  Boolean   @default(false)
  tags      String[]

  @@map("blog_post")
}

model Project {
  id           Int       @id @default(autoincrement())
  title        String
  description  String
  image        String?
  technologies String[]
  category     String
  github       String?
  live         String?
  featured     Boolean   @default(false)

  @@map("project")
}