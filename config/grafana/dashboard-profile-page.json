{
	"__inputs": [
		{
			"name": "DS_PROMETHEUS",
			"label": "Prometheus",
			"description": "Grafana Cloud Prometheus (OTLP metrics)",
			"type": "datasource",
			"pluginId": "prometheus",
			"pluginName": "Prometheus"
		},
		{
			"name": "DS_TEMPO",
			"label": "Tempo",
			"description": "Grafana Cloud Traces",
			"type": "datasource",
			"pluginId": "tempo",
			"pluginName": "Tempo"
		}
	],
	"__requires": [
		{ "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
		{ "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
		{ "type": "datasource", "id": "tempo", "name": "Tempo", "version": "1.0.0" }
	],
	"annotations": { "list": [] },
	"editable": true,
	"fiscalYearStartMonth": 0,
	"graphTooltip": 1,
	"links": [],
	"panels": [
		{
			"id": 1,
			"type": "timeseries",
			"title": "HTTP request rate",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"targets": [
				{
					"expr": "sum(rate(app_http_requests_total{service_name=\"profile-page\"}[$__rate_interval])) by (http_method)",
					"legendFormat": "{{http_method}}",
					"refId": "A"
				}
			],
			"fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
		},
		{
			"id": 2,
			"type": "timeseries",
			"title": "HTTP 5xx / unhandled errors",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"targets": [
				{
					"expr": "sum(rate(app_http_errors_total{service_name=\"profile-page\"}[$__rate_interval]))",
					"legendFormat": "errors/s",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } },
				"overrides": []
			}
		},
		{
			"id": 3,
			"type": "timeseries",
			"title": "Contact form submissions",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"targets": [
				{
					"expr": "sum(rate(app_contact_submissions_total{service_name=\"profile-page\"}[$__rate_interval])) by (outcome)",
					"legendFormat": "{{outcome}}",
					"refId": "A"
				}
			],
			"fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
		},
		{
			"id": 4,
			"type": "timeseries",
			"title": "Rate limit rejections (429)",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
			"datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
			"targets": [
				{
					"expr": "sum(rate(app_rate_limit_exceeded_total{service_name=\"profile-page\"}[$__rate_interval]))",
					"legendFormat": "429/s",
					"refId": "A"
				}
			],
			"fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
		},
		{
			"id": 5,
			"type": "traces",
			"title": "Recent traces",
			"gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
			"datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
			"targets": [
				{
					"queryType": "traceql",
					"query": "{ resource.service.name = \"profile-page\" }",
					"refId": "A"
				}
			]
		}
	],
	"refresh": "30s",
	"schemaVersion": 39,
	"tags": ["profile-page", "otel", "portfolio"],
	"templating": { "list": [] },
	"time": { "from": "now-6h", "to": "now" },
	"timepicker": {},
	"timezone": "browser",
	"title": "profile-page",
	"uid": "profile-page-otel",
	"version": 1,
	"weekStart": ""
}
